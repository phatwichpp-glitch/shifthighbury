# ─────────────────────────────────────────────────────────────────────────────
# .env.example — คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริงทุกบรรทัด
# Copy this file to .env and fill in all values before running the app.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google OAuth ──────────────────────────────────────────────────────────────
# สร้างที่ Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# ประเภท: Web application | ต้องเปิด Sheets API, Drive API, Calendar API ด้วย
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Type: OAuth 2.0 Client ID (Web application) — no Client Secret needed in this SPA.
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# ── WebRTC Signaling (Cloudflare Worker) ──────────────────────────────────────
# URL ของ Cloudflare Worker ที่ deploy แล้ว — ดู webrtc-signaling/ และ SETUP.md
# Deploy webrtc-signaling/ to Cloudflare Workers, then paste the worker URL here.
# Example: https://webrtc-signaling.YOUR_ACCOUNT.workers.dev
VITE_WEBRTC_SIGNALING_URL=https://YOUR_WORKER_NAME.YOUR_ACCOUNT.workers.dev

# ── TURN Server ───────────────────────────────────────────────────────────────
# จำเป็นสำหรับ WebRTC video call ผ่าน NAT/firewall
# รับ free credentials ได้ที่ https://dashboard.metered.ca หรือ provider อื่น
# Required for WebRTC calls through firewalls / symmetric NAT.
# Get free credentials at https://dashboard.metered.ca (or any TURN provider).
#
# SECURITY NOTE: TURN credentials are sent to the browser intentionally —
# the browser contacts the TURN server directly (WebRTC requirement).
# Rotate immediately if these values are ever committed to a public repository.
VITE_TURN_USERNAME=YOUR_TURN_USERNAME
VITE_TURN_CREDENTIAL=YOUR_TURN_CREDENTIAL

# ── Teacher Secret ────────────────────────────────────────────────────────────
# ต้องตรงกับ TEACHER_SECRET ใน Cloudflare Worker (ตั้งด้วย: wrangler secret put TEACHER_SECRET)
# ใช้ยืนยันตัวตนครูกับ endpoints ฝั่งจัดการ (config/sheet, class-code, push/send ฯลฯ)
# Must match the TEACHER_SECRET secret in webrtc-signaling (wrangler secret put TEACHER_SECRET)
VITE_TEACHER_SECRET=YOUR_TEACHER_SECRET

# ── Web Push Notifications (VAPID) ────────────────────────────────────────────
# Public key สำหรับ Web Push — ต้องตรงกับ VAPID_PUBLIC_KEY ใน wrangler.jsonc
# สร้างคู่ key ใหม่ด้วย: npx web-push generate-vapid-keys
# Must match VAPID_PUBLIC_KEY in webrtc-signaling/wrangler.jsonc
# Generate a new key pair with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
